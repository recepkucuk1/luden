generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Therapist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  specialty String[] // ["speech", "language", "hearing"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  Student[]
  cards     Card[]
  progress  StudentProgress[]
}

model Student {
  id            String    @id @default(cuid())
  name          String
  birthDate     DateTime?
  workArea      String    @default("speech") // "speech" | "language" | "hearing"
  diagnosis     String?
  notes         String?
  curriculumIds String[]  @default([])
  aiProfile     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id])
  cards       Card[]
  assignments CardAssignment[]
  progress    StudentProgress[]
}

model Card {
  id         String   @id @default(cuid())
  title      String
  content    Json
  category   String   // "speech" | "language" | "hearing"
  difficulty String   // "easy" | "medium" | "hard"
  ageGroup   String   // "3-6" | "7-12" | "13-18" | "adult"
  prompt     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  curriculumGoalId String?
  curriculumGoal   CurriculumGoal? @relation(fields: [curriculumGoalId], references: [id])

  assignments CardAssignment[]
}

model CardAssignment {
  id         String   @id @default(cuid())
  cardId     String
  studentId  String
  assignedAt DateTime @default(now())

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([cardId, studentId])
}

model Curriculum {
  id    String @id @default(cuid())
  code  String // "1.1", "1.2"
  area  String // "speech" | "language" | "hearing"
  title String // "Kekemelik"

  goals CurriculumGoal[]
}

model CurriculumGoal {
  id         String  @id @default(cuid())
  code       String  // "1.0", "1.1", "2.0"
  title      String  // "Konuşma sırasında nefes kontrolünü sağlar"
  isMainGoal Boolean // true = ana hedef (1.0), false = alt hedef (1.1)

  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  cards    Card[]
  progress StudentProgress[]
}

model StudentProgress {
  id        String   @id @default(cuid())
  status    String   // "not_started" | "in_progress" | "completed"
  notes     String?
  updatedAt DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  goalId String
  goal   CurriculumGoal @relation(fields: [goalId], references: [id])

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@unique([studentId, goalId])
}

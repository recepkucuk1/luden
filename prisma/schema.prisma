generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanType {
  FREE
  PRO
  ADVANCED
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum CreditTransactionType {
  EARN
  SPEND
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum ToolType {
  LEARNING_CARD
  SOCIAL_STORY
  ARTICULATION_DRILL
  HOMEWORK_MATERIAL
  WEEKLY_PLAN
  SESSION_SUMMARY
  MATCHING_GAME
  PHONATION_ACTIVITY
  COMMUNICATION_BOARD
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Therapist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  specialty String[] // ["speech", "language", "hearing"]
  role      String   @default("user") // "user" | "admin"
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?   @unique
  emailVerifyExpires DateTime?
  credits      Int      @default(40)
  studentLimit Int      @default(2)
  pdfEnabled   Boolean  @default(false)
  planType     PlanType @default(FREE)
  suspended    Boolean  @default(false)
  lastLogin    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students           Student[]
  cards              Card[]
  progress           StudentProgress[]
  subscriptions      Subscription[]
  creditTxns         CreditTransaction[]
  lessons            Lesson[]
  passwordResetTokens PasswordResetToken[]
}

model Plan {
  id           String   @id @default(cuid())
  type         PlanType @unique
  studentLimit Int      // -1 = sınırsız
  creditAmount Int      // dönem başı yüklenen kredi
  monthlyPrice Int      // kuruş cinsinden (37900 = 379 TL)
  yearlyPrice  Int      // kuruş cinsinden
  pdfEnabled   Boolean
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  therapistId      String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  billingCycle     BillingCycle
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])
}

model CreditTransaction {
  id          String                @id @default(cuid())
  therapistId String
  amount      Int
  type        CreditTransactionType
  description String
  createdAt   DateTime              @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
}

model Student {
  id            String    @id @default(cuid())
  name          String
  birthDate     DateTime?
  workArea      String    @default("speech") // "speech" | "language" | "hearing"
  diagnosis     String?
  notes         String?
  curriculumIds String[]  @default([])
  aiProfile     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  cards       Card[]
  assignments CardAssignment[]
  progress    StudentProgress[]
  lessons     Lesson[]

  @@index([therapistId])
}

model Card {
  id         String   @id @default(cuid())
  title      String
  content    Json
  toolType   ToolType @default(LEARNING_CARD)
  category   String   @default("generator") // "speech" | "language" | "hearing" | "generator"
  difficulty String   // "easy" | "medium" | "hard"
  ageGroup   String   // "3-6" | "7-12" | "13-18" | "adult"
  prompt     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  curriculumGoalIds String[] @default([])

  assignments CardAssignment[]

  @@index([therapistId])
  @@index([studentId])
  @@index([category])
}

model CardAssignment {
  id         String   @id @default(cuid())
  cardId     String
  studentId  String
  status     String   @default("not_started") // "not_started" | "in_progress" | "completed"
  assignedAt DateTime @default(now())

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([cardId, studentId])
}

model Curriculum {
  id    String @id @default(cuid())
  code  String // "1.1", "1.2"
  area  String // "speech" | "language" | "hearing"
  title String // "Kekemelik"

  goals CurriculumGoal[]
}

model CurriculumGoal {
  id         String  @id @default(cuid())
  code       String  // "1.0", "1.1", "2.0"
  title      String  // "Konuşma sırasında nefes kontrolünü sağlar"
  isMainGoal Boolean // true = ana hedef (1.0), false = alt hedef (1.1)

  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  progress StudentProgress[]
}

model Lesson {
  id           String       @id @default(cuid())
  therapistId  String
  studentId    String
  title        String
  date         DateTime
  startTime    String       // "09:00"
  endTime      String       // "10:00"
  note         String?
  isRecurring  Boolean      @default(false)
  recurringDay Int?         // 0=Pazar, 1=Pazartesi ... 6=Cumartesi
  status       LessonStatus @default(PLANNED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([therapistId])
  @@index([date])
}

model StudentProgress {
  id        String   @id @default(cuid())
  status    String   // "not_started" | "in_progress" | "completed"
  notes     String?
  updatedAt DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  goalId String
  goal   CurriculumGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([studentId, goalId])
  @@index([therapistId])
  @@index([status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user Therapist @relation(fields: [userId], references: [id], onDelete: Cascade)
}
